# ============================================================
# Donna environment configuration
# Copy to .env for local development. Every value has a safe
# local default — Donna boots with NO env vars set (demo mode).
# ============================================================

# ---- Core server ----
DONNA_PORT=3001
DONNA_HOST=0.0.0.0
# Secret for cookie signing + encrypting API keys stored via the UI.
# REQUIRED in production. A dev fallback is used locally (with a warning).
DONNA_SECRET=change-me-in-production
# Log level: fatal|error|warn|info|debug|trace
DONNA_LOG_LEVEL=info

# ---- Database ----
# Default: local SQLite at ./data/donna.db
# Cloud: set a postgres:// URL (managed Postgres)
# DATABASE_URL=postgres://user:pass@host:5432/donna

# ---- Storage ----
# Local file storage root (uploads, sqlite db)
DONNA_DATA_DIR=./data
# Object storage for uploads in cloud mode: local|s3
DONNA_STORAGE_DRIVER=local
# DONNA_S3_BUCKET=
# DONNA_S3_REGION=
# DONNA_S3_ENDPOINT=            # optional, for MinIO/R2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ---- Auth ----
# local    = single-user, auto-login (default; for local use)
# password = email+password login (set for cloud deployments)
DONNA_AUTH_MODE=local
# Initial owner account (used on first boot)
DONNA_OWNER_EMAIL=you@example.com
DONNA_OWNER_NAME=Donna User
# DONNA_OWNER_PASSWORD=        # required when DONNA_AUTH_MODE=password

# ---- Demo data ----
# Seed a demo workspace with mock email/chat/calendar/storage sources on
# first boot so the product works with zero external accounts.
DONNA_DEMO_SEED=true

# ---- Web (dev) ----
DONNA_WEB_ORIGIN=http://localhost:5173
# Serve a built web bundle from the API server (set in Docker):
# DONNA_PUBLIC_DIR=/app/apps/web/dist

# ============================================================
# LLM providers (all optional — without any, Donna runs in
# demo mode with mock responses and a clear UI warning).
# Providers are managed in Settings → AI Providers; these env
# vars bootstrap initial configs on first boot.
# ============================================================
# Cloud providers
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# Local / OpenAI-compatible inference (vLLM, Ollama, SGLang, LM Studio, ...)
# DONNA_LOCAL_LLM_BASE_URL=http://localhost:11434/v1   # Ollama example
# DONNA_LOCAL_LLM_MODEL=llama3.1:8b
# DONNA_LOCAL_LLM_API_KEY_ENV=                          # env var NAME holding the key, if any
# DONNA_LOCAL_EMBEDDING_MODEL=nomic-embed-text

# ============================================================
# Connectors (all optional — mock connectors need nothing).
# See docs/connectors.md for full setup of each provider.
# ============================================================
# Google (Gmail / Calendar / Drive): OAuth refresh-token flow
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
# Microsoft (Outlook / Teams / OneDrive): Graph API
# MS_CLIENT_ID=
# MS_CLIENT_SECRET=
# MS_TENANT_ID=
# MS_REFRESH_TOKEN=
# Slack
# SLACK_BOT_TOKEN=
# AWS S3 source bucket
# DONNA_SOURCE_S3_BUCKET=
# DONNA_SOURCE_S3_REGION=
