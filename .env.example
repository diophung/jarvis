# ============================================================
# Jarvis environment configuration
# Copy to .env for local development. Every value has a safe
# local default — Jarvis boots with NO env vars set (demo mode).
# ============================================================

# ---- Core server ----
JARVIS_PORT=3001
JARVIS_HOST=0.0.0.0
# Secret for cookie signing + encrypting API keys stored via the UI.
# REQUIRED in production. A dev fallback is used locally (with a warning).
JARVIS_SECRET=change-me-in-production
# Log level: fatal|error|warn|info|debug|trace
JARVIS_LOG_LEVEL=info

# ---- Database ----
# Default: local SQLite at ./data/jarvis.db
# Cloud: set a postgres:// URL (Aurora / AlloyDB / Cloud SQL / Neon).
# Use sslmode=require in production. See docs/production-database.md.
# DATABASE_URL=postgres://user:pass@host:5432/jarvis?sslmode=require
# Connection pool + safety rails (per process; defaults shown)
# JARVIS_DB_POOL_SIZE=10
# JARVIS_DB_CONNECT_TIMEOUT_MS=5000
# JARVIS_DB_IDLE_TIMEOUT_MS=30000
# JARVIS_DB_STATEMENT_TIMEOUT_MS=10000
# JARVIS_DB_SLOW_QUERY_MS=250

# ---- Cache (optional; in-memory per process when unset) ----
# Redis/Valkey-compatible URL (ElastiCache, Memorystore, Upstash).
# The cache is disposable — Jarvis works identically without it.
# JARVIS_REDIS_URL=redis://localhost:6379
# JARVIS_CACHE_TTL_SECONDS=60

# ---- Storage ----
# Local file storage root (uploads, sqlite db)
JARVIS_DATA_DIR=./data
# Object storage for uploads in cloud mode: local|s3
JARVIS_STORAGE_DRIVER=local
# JARVIS_S3_BUCKET=
# JARVIS_S3_REGION=
# JARVIS_S3_ENDPOINT=            # optional, for MinIO/R2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ---- Worker ----
# Run the scheduler (digests, syncs, approval expiry) inside the API process.
# Set to false when running the dedicated worker (docker-compose does this).
JARVIS_INLINE_WORKER=true

# ---- Auth ----
# Set the session cookie's Secure attribute (enable when serving over HTTPS;
# required for Apple login)
JARVIS_COOKIE_SECURE=false
# Trust X-Forwarded-* headers — set true when behind a reverse proxy so
# rate limiting sees real client IPs.
JARVIS_TRUST_PROXY=false
# local    = single-user, auto-login (default; for local use)
# password = email+password login + optional OAuth login (set for cloud)
JARVIS_AUTH_MODE=local
# Initial owner account (used on first boot)
JARVIS_OWNER_EMAIL=you@example.com
JARVIS_OWNER_NAME=Jarvis User
# JARVIS_OWNER_PASSWORD=        # required when JARVIS_AUTH_MODE=password
# Allow self-service registration in password mode (default true)
# JARVIS_ALLOW_SIGNUP=true
# Public base URL of the API — OAuth redirect URIs are built from it.
# Default: http://localhost:<JARVIS_PORT>. REQUIRED behind a reverse proxy.
# JARVIS_PUBLIC_URL=https://jarvis.example.com
# Dedicated key for OAuth-token encryption at rest (default: JARVIS_SECRET).
# Rotate with: JARVIS_OLD_KEY=<old> pnpm --filter @jarvis/server exec tsx src/scripts/rotate-token-key.ts
# JARVIS_TOKEN_ENCRYPTION_KEY=

# ---- OAuth login providers (docs/auth.md) ----
# Each provider appears on the sign-in page once its vars are set.
# Google login shares the client with the Gmail/Drive/Calendar connect flow.
# Redirect URI: <JARVIS_PUBLIC_URL>/api/auth/oauth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Redirect URI: <JARVIS_PUBLIC_URL>/api/auth/oauth/facebook/callback
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=
# Apple (HTTPS only): Services ID + Sign in with Apple key (ES256 .p8).
# Redirect URI: <JARVIS_PUBLIC_URL>/api/auth/oauth/apple/callback
# APPLE_CLIENT_ID=
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# ---- Demo data ----
# Seed a demo workspace with mock email/chat/calendar/storage sources on
# first boot so the product works with zero external accounts.
JARVIS_DEMO_SEED=true

# ---- Web (dev) ----
JARVIS_WEB_ORIGIN=http://localhost:5173
# Serve a built web bundle from the API server (set in Docker):
# JARVIS_PUBLIC_DIR=/app/apps/web/dist

# ============================================================
# LLM providers (all optional — without any, Jarvis runs in
# demo mode with mock responses and a clear UI warning).
# Providers are managed in Settings → AI Providers; these env
# vars bootstrap initial configs on first boot.
# ============================================================
# Cloud providers
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# Local / OpenAI-compatible inference (vLLM, Ollama, SGLang, LM Studio, ...)
# JARVIS_LOCAL_LLM_BASE_URL=http://localhost:11434/v1   # Ollama example
# JARVIS_LOCAL_LLM_MODEL=llama3.1:8b
# JARVIS_LOCAL_LLM_API_KEY_ENV=                          # env var NAME holding the key, if any
# JARVIS_LOCAL_EMBEDDING_MODEL=nomic-embed-text

# ============================================================
# Connectors (all optional — mock connectors need nothing).
# See docs/connectors.md for full setup of each provider.
# ============================================================
# Google (Gmail / Calendar / Drive): with GOOGLE_CLIENT_ID/SECRET set (above),
# connect via the OAuth buttons in Settings → Connected Sources — no refresh
# token needed. GOOGLE_REFRESH_TOKEN is the advanced/headless env path.
# Source redirect URI: <JARVIS_PUBLIC_URL>/api/sources/oauth/google/callback
# GOOGLE_REFRESH_TOKEN=
# Microsoft (Outlook / Teams / OneDrive): Graph API
# MS_CLIENT_ID=
# MS_CLIENT_SECRET=
# MS_TENANT_ID=
# MS_REFRESH_TOKEN=
# Slack
# SLACK_BOT_TOKEN=
# AWS S3 source bucket
# JARVIS_SOURCE_S3_BUCKET=
# JARVIS_SOURCE_S3_REGION=
